# ==========================================
# LPI AI Agent - Enterprise Configuration
# ==========================================

# 1. Execution Environment
ENVIRONMENT=development        # Options: development, production, test
DEBUG_MODE=true                # Set to false in production to prevent data leakage

# 2. LPI MCP Server Configuration
LPI_SERVER_PATH=/path/to/lpi-developer-kit/dist/test-client.js
LPI_SERVER_TIMEOUT_MS=10000    # Maximum wait time for subprocess execution (Fail-safe)

# 3. AI Model Configuration (Local/Ollama)
OLLAMA_MODEL=qwen2.5:1.5b      # Primary model for inference
OLLAMA_HOST=http://localhost:11434
MAX_TOKENS=2048                # Context window limit
TEMPERATURE=0.2                # Low temperature for deterministic, grounded outputs

# 4. Agent Mesh & Security Settings
A2A_BROADCAST_PORT=8080        # Port for A2A discovery card broadcasting
SECURE_MESH_ENABLED=true       # Enforces strict JSON validation on all tool responses